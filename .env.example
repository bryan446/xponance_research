# Add your OpenAI API key only for graph creation and rebuilds.
OPENAI_API_KEY=

# Optional: if omitted, PDFs fall back to local parsing rather than LlamaParse.
LLAMA_PARSE_API_KEY=
LLAMA_PARSE_RESULT_TYPE=markdown

GRAPH_LLM_MODEL=gpt-4o

NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

RAG_DATA_DIR=knowledge_base
RAG_GRAPH_STATE_FILE=.neo4j_graph_state.json
RAG_APP_NAME=xponance-research
RAG_DEFAULT_TOP_K=5
RAG_ALLOWED_EXTENSIONS=.md,.pdf
RAG_EXCLUDED_DIRS=.git,.venv,__pycache__,.mypy_cache,.pytest_cache,scripts,llamacloud_rag,codex,docs,node_modules,plugins,.agents
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=128
